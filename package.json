{
  "name": "@philiprehberger/react-ui-kit",
  "version": "0.1.5",
  "description": "Accessible React UI component library with Tailwind CSS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "clsx": ">=2.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "clsx": "^2.1.0",
    "react": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "accessible",
    "design-system"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-react-ui-kit.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-react-ui-kit#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-react-ui-kit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
